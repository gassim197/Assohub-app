# Base de données (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth (Better-Auth) — générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Connexion Google (Better-Auth social provider). À créer dans Google Cloud
# Console > APIs & Services > Credentials > OAuth client ID (type
# "Application Web"). Ajouter comme "Authorized redirect URI" :
#   - dev  : http://localhost:3000/api/auth/callback/google
#   - prod : https://assohub-gn.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
